# OpenRouter API Keys (for production on Vercel)
# Get your API keys from https://openrouter.ai/keys
# Multiple keys can be comma-separated for fallback (first one is primary)
# Example: key1,key2,key3
VITE_OPENROUTER_API_KEYS=your_api_key_here

# Single key (legacy - still works but VITE_OPENROUTER_API_KEYS takes priority)
# VITE_OPENROUTER_API_KEY=your_api_key_here

# Model to use (optional - defaults to openai/gpt-oss-20b:free)
VITE_OPENROUTER_MODEL=openai/gpt-oss-20b:free